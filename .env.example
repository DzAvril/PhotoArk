NODE_ENV=development
API_PORT=8080
WEB_PORT=5173
PHOTOARK_IMAGE=dzavril/photoark:latest
POSTGRES_URL=postgresql://photoark:photoark@postgres:5432/photoark
REDIS_URL=redis://redis:6379
BACKUP_STATE_FILE=./apps/api/data/backup-state.json
FS_BROWSE_ROOT=/
WATCH_USE_POLLING=false
WATCH_POLLING_INTERVAL_MS=1000
WATCH_RECONCILE_INTERVAL_MS=30000
WATCH_SETTLE_DELAY_MS=5000
WATCH_BATCH_MAX_WAIT_MS=600000
MEMORY_PROFILING_ENABLED=false
MEMORY_SAMPLE_INTERVAL_MS=10000
MEMORY_SAMPLE_LIMIT=720
MEMORY_SAMPLE_RECENT_LIMIT=60
MEMORY_SNAPSHOT_DIR=./apps/api/data/memory-snapshots
MEMORY_AUTO_SNAPSHOT_ENABLED=false
MEMORY_AUTO_SNAPSHOT_INTERVAL_MS=600000
MEMORY_AUTO_SNAPSHOT_MAX_FILES=20
MEMORY_AUTO_SNAPSHOT_RSS_THRESHOLD_MB=0
AUTH_SESSION_TTL_HOURS=168
APP_VERSION=0.1.28
VERSION_CHECK_REPO=DzAvril/PhotoArk
VERSION_CHECK_TIMEOUT_MS=3500
GITHUB_TOKEN=
MASTER_KEY_BASE64=replace_with_32_byte_base64_key
LEGACY_MASTER_KEYS_BASE64=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
VITE_API_BASE_URL=
